{
  "$schema": "https://opencode.ai/config.json",
  "plugin": ["opencode-beads"],
  "model": "openrouter/qwen3.6-plus-preview-free",
  "agent": {
    "general": {
      "description": "General-purpose agent implementing code and executing multi-step tasks",
      "mode": "subagent",
      "model": "openrouter/qwen3.6-plus-preview-free"
    },
    "explore": {
      "description": "Fast agent specialized for exploring codebases",
      "mode": "subagent",
      "model": "openrouter/qwen3.6-plus-preview-free",
      "permission": {
        "write": "deny",
        "edit": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "codesearch": "allow",
        "bash": {
          "*": "deny",
          "ck *": "allow",
          "grep *": "allow",
          "rg *": "allow",
          "cat *": "allow",
          "sed *": "allow",
          "awk *": "allow",
          "cut *": "allow",
          "sort *": "allow",
          "uniq *": "allow",
          "tr *": "allow",
          "jq *": "allow",
          "column *": "allow",
          "diff *": "allow",
          "git log *": "allow",
          "git diff *": "allow",
          "git show *": "allow",
          "git blame *": "allow",
          "head *": "allow",
          "tail *": "allow",
          "wc *": "allow",
          "file *": "allow",
          "stat *": "allow"
        }
      }
    },
    "diagnose": {
      "description": "Senior diagnostic expert for hard problems",
      "mode": "subagent",
      "model": "github-copilot/claude-opus-4.6"
    }
  },
  "mcp": {
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp@latest"
      ]
    },
    "togather": {
      "type": "remote",
      "enabled": true,
      "url": "https://staging.toronto.togather.foundation/mcp",
      "headers": {
        "Authorization": "Bearer {env:TOGATHER_MCP_API_KEY}"
      },
      "oauth": false
    }
  }
}